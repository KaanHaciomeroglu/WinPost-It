{
  "name": "postit-app",
  "version": "1.0.1",
  "description": "Windows masaüstü post-it uygulaması",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64"
  },
  "build": {
    "appId": "com.postit.app",
    "productName": "Post-it",
    "icon": "assets/icon.ico",
    "asar": false,
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico",
      "forceCodeSigning": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "Post-it"
    },
    "files": [
      "main.js",
      "preload.js",
      "preload-dialog.js",
      "src/**",
      "assets/**"
    ]
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^26.8.1",
    "electron-packager": "^17.1.2",
    "png2icons": "^2.0.1"
  }
}
